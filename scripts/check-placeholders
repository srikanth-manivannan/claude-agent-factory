#!/usr/bin/env sh
# Fail if any artifact contains a leftover {{PLACEHOLDER}}. Pure shell, no runtime.
# Tech-profile fields may be "n/a", but the {{ }} braces must be gone.
. "$(dirname -- "$0")/lib/common.sh"

found=0
for d in $(list_artifacts); do
  hits=$(grep -rl '{{' "$d" 2>/dev/null || true)
  if [ -n "$hits" ]; then
    for f in $hits; do
      err "leftover placeholder: ${f#"$ROOT"/}"
      found=$((found + 1))
    done
  fi
done

if [ "$found" -gt 0 ]; then
  err "check-placeholders: $found file(s) with leftover placeholders"
  exit 1
fi
ok "check-placeholders: OK (no leftover placeholders)"
